- ref:
  - https://artifacthub.io/packages/helm/jenkinsci/jenkins

```sh
kubectl apply -f jenkins/pvc.yaml
helm upgrade --install jenkins jenkins/jenkins -f jenkins/values.yaml
kubectl --namespace default port-forward svc/jenkins 8080:8080
# kubectl exec --namespace default -it svc/jenkins -c jenkins -- /bin/cat /run/secrets/additional/chart-admin-password

helm uninstall jenkins

```

- repo
  - https://github.com/simonangel-fong/Jenkins_Demo_SpringBoot_ECR.git
  - master
  - cicd/ci/Jenkinsfile

```sh
kubectl create secret generic jenkins-secrets \
  --from-literal=aws-access-key-id='' \
  --from-literal=aws-secret-access-key='' \
  --from-literal=github-token=''  \
  --from-literal=tf-state-bucket='' \
  --from-literal=mail-smtp-host='smtp.gmail.com' \
  --from-literal=mail-smtp-port='465' \
  --from-literal=mail-smtp-user='' \
  --from-literal=mail-smtp-password=''


kubectl create secret generic jenkins-admin \
  --from-literal=jenkins-admin-user=admin \
  --from-literal=jenkins-admin-password=''

kubectl delete secret jenkins-secrets
kubectl delete secret jenkins-admin

```